# Supabase — copy to `.env.local` and fill the anon key.
# Dashboard: Project Settings → API → Project API keys → anon (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Expo app (`apps/mobile/.env`) — same values as above, EXPO_PUBLIC_* prefix; never service role here.
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-only (never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: GA4 measurement ID — enables `gtag` forwarding from `trackProductEvent` (see `src/lib/analytics/track-client.ts`).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: canonical public site URL (https://…) — used for metadataBase, canonical URLs, sitemap.
# NEXT_PUBLIC_SITE_URL=

# Search indexing — defaults are safe (see src/lib/meta/indexing.ts). Uncomment to force off or to allow indexing on non-Vercel production.
# NEXT_PUBLIC_INDEXING_DISABLED=true
# NEXT_PUBLIC_ALLOW_SEARCH_INDEXING=true

# Optional: visible support / abuse mailto links on /contact and /settings/data
# NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL=
# NEXT_PUBLIC_ABUSE_CONTACT_EMAIL=

# Optional: log slow server actions — see docs/OBSERVABILITY.md
# DJCN_LOG_SERVER_ACTION_TIMING=true
# DJCN_SLOW_ACTION_MS=2000

# Optional: account deletion ops digest — see docs/ACCOUNT_DELETION_OPS_DIGEST.md
# No default URL; leave unset for stdout-only. Same severity labels as v_account_deletion_open_ops.
# GitHub Actions: set NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY as repo *secrets* for workflow.
# ACCOUNT_DELETION_OPS_WEBHOOK_URL=
# ACCOUNT_DELETION_OPS_WEBHOOK_BEARER=
# ACCOUNT_DELETION_OPS_WEBHOOK_FORMAT=json
# ACCOUNT_DELETION_OPS_DIGEST_NOTIFY=action_or_warning
