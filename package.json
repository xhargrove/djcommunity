{
  "name": "djcommunity",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "npm run lint && npm run typecheck && npm test",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "execute:account-deletion": "tsx --env-file=.env.local scripts/execute-account-deletion.ts",
    "reconcile:account-deletion": "tsx --env-file=.env.local scripts/reconcile-account-deletion.ts",
    "ops:account-deletion": "tsx --env-file=.env.local scripts/account-deletion-ops-snapshot.ts",
    "digest:account-deletion": "tsx --env-file=.env.local scripts/account-deletion-ops-digest.ts",
    "digest:account-deletion:ci": "tsx scripts/account-deletion-ops-digest.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.3",
    "server-only": "^0.0.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.4"
  }
}
